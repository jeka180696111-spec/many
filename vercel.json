{
  "rewrites": [
    { "source": "/mh/:secret", "destination": "/api/mono?action=webhook&s=:secret" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/telegram-summary", "schedule": "0 19 * * *" },
    { "path": "/api/cron-push",        "schedule": "0 9 * * *"  }
  ]
}
